FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 17401

# Том node_modules живёт своей жизнью: при смене lock-файла нужен повторный npm ci (иначе «Failed to resolve import»).
CMD ["sh", "-c", "if [ ! -d node_modules/vite ] || [ ! -f node_modules/.docker_deps_stamp ] || [ package-lock.json -nt node_modules/.docker_deps_stamp ]; then npm ci && touch node_modules/.docker_deps_stamp; fi && exec npm run dev -- --host 0.0.0.0 --port 17401"]
