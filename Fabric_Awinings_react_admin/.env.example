COMPOSE_PROJECT_NAME=fabric-awnings-react-admin
# Django API на хосте
FABRIC_RA_API_PORT=18100
# Витрина (Vite на хосте; внутри контейнера всегда 17300). 17300 часто занят проектом Fabric_Awinings — по умолчанию в compose 17302.
FABRIC_FRONTEND_PORT=17302
# React Admin — вход http://localhost:17401/staff/ (Django Unfold на API — …/admin/)
FABRIC_ADMIN_UI_PORT=17401
# Витрина в Docker: в compose по умолчанию VITE_API_URL=http://localhost:18100 (порт FABRIC_RA_API_PORT). Иначе /api через прокси Vite.
# VITE_API_URL=http://localhost:18100
# Браузер → API и CORS: CSRF должен включать те же origin (витрина + RA + прямой API).
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:17302,http://127.0.0.1:17302,http://localhost:17401,http://127.0.0.1:17401,http://localhost:18100,http://127.0.0.1:18100
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:17302,http://127.0.0.1:17302,http://localhost:17401,http://127.0.0.1:17401,http://localhost:18100,http://127.0.0.1:18100
# Ссылка «на сайт» в письмах/редиректах
# DJANGO_PUBLIC_SITE_URL=http://localhost:17302
# Классическая админка Django (Unfold) на http://localhost:18100/admin/ — в docker-compose по умолчанию включена.
# Отключить (только React Admin на :17401, а :18100/admin → редирект на SPA): DJANGO_ADMIN_ENABLED=false
# DJANGO_ADMIN_ENABLED=false
# Редирект …/admin/* → React, если админка выключена (порт как у FABRIC_ADMIN_UI_PORT).
# DJANGO_ADMIN_REDIRECT_URL=http://localhost:17401/admin/

# Витрина (frontend): кнопки входа в футере — задаются при сборке Vite (обязательны для production).
# VITE_PUBLIC_REACT_ADMIN_URL=https://site.example.com/staff/
# VITE_PUBLIC_DJANGO_ADMIN_URL=https://api.example.com/admin/
