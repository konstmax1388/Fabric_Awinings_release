FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 17300

# Порт совпадает с vite.config (на хосте в compose всё равно маппится FABRIC_FRONTEND_PORT:17300 → 17300).
CMD ["sh", "-c", "npm ci && exec npm run dev -- --host 0.0.0.0 --port 17300"]
