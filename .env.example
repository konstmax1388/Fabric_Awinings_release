# Скопируйте в .env. Порты не должны пересекаться с другими проектами.
COMPOSE_PROJECT_NAME=fabric-awnings
FABRIC_FRONTEND_PORT=17300
FABRIC_API_PORT=18000
# React Admin (admin-ui): http://localhost:17401/admin/
FABRIC_ADMIN_UI_PORT=17401
# URL API для браузера (с хоста Windows/Mac), не имя сервиса Docker:
VITE_API_URL=http://localhost:18000
# Куда Vite проксирует /admin и /static (только для процесса dev-сервера). Локально не задавайте — возьмётся VITE_API_URL.
# В docker-compose задано http://api:8000 автоматически.
# VITE_PROXY_TARGET=http://127.0.0.1:18000
# Канонический URL фронта для meta/sitemap (опционально; иначе берётся window.location.origin)
# VITE_SITE_URL=http://localhost:17300
# Опционально: список origin для CORS (через запятую)
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:17300,http://127.0.0.1:17300,http://localhost:17301,http://127.0.0.1:17301,http://localhost:17401,http://127.0.0.1:17401
# Те же origin для CSRF (вход в /admin/ через прокси Vite; прямой заход на порт API)
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:17300,http://127.0.0.1:17300,http://localhost:17301,http://127.0.0.1:17301,http://localhost:17401,http://127.0.0.1:17401,http://localhost:18000,http://127.0.0.1:18000

# Вход в Django Admin при разработке (команда ensure_dev_admin, только если DJANGO_DEBUG не false):
# DJANGO_DEV_ADMIN_USERNAME=dev
# DJANGO_DEV_ADMIN_PASSWORD=devdev
# DJANGO_DEV_ADMIN_EMAIL=dev@dev.local
# Публичный URL витрины (кнопка «на сайт» в админке Unfold)
# DJANGO_PUBLIC_SITE_URL=http://localhost:17300

# Капча на /admin/login/ (django-simple-captcha). При DJANGO_DEBUG=true по умолчанию выкл.;
# включить локально: DJANGO_ADMIN_CAPTCHA=true. На проде (DEBUG=false) — вкл.; выкл.: DJANGO_ADMIN_CAPTCHA=false
# DJANGO_ADMIN_CAPTCHA=true

# --- Прод: MySQL 8.x — при заданных DJANGO_MYSQL_* Django переключается с SQLite (см. config/settings.py).
# pip на сервере: requirements-prod.txt (mysqlclient + gunicorn). Шаблон env: .env.production.example
# DJANGO_MYSQL_HOST=127.0.0.1
# DJANGO_MYSQL_PORT=3306
# DJANGO_MYSQL_DATABASE=fabrica-tentov
# DJANGO_MYSQL_USER=
# DJANGO_MYSQL_PASSWORD=

# --- CRM: Astrum «Заявки с сайта» → Битрикс24 (см. docs/astrum-bitrix-crm.md) ---
# Без ключа и ASTRUM_CRM_ASSIGNED_DEFAULT интеграция выключена.
# ASTRUM_CRM_API_KEY=
# ASTRUM_CRM_ASSIGNED_DEFAULT=1
# ASTRUM_CRM_API_URL=https://app-5.astrum.agency/api/order
# ASTRUM_CRM_CONTACT_BEHAVIOR=SELECT_EXISTING
# ASTRUM_CRM_ENTITY_BEHAVIOR=CREATE_ANYWAY
# ASTRUM_CRM_DEAL_TITLE_PREFIX=Заказ с сайта
# ASTRUM_CRM_TIMEOUT=15

# --- Массовое сопоставление каталога с Б24 (команда sync_bitrix_catalog_ids) ---
# Чаще задаётся в админке: Настройки сайта → «Битрикс24: REST каталог».
# Если там пусто — можно через env (вебхук с правом «Каталог», без завершающего слэша):
# BITRIX24_WEBHOOK_BASE=https://yourportal.bitrix24.ru/rest/1/your_secret
# BITRIX24_CATALOG_PRODUCT_IBLOCK_ID=
# BITRIX24_CATALOG_OFFER_IBLOCK_ID=

# --- Оформление: СДЭК API v2 (приоритет над полями в админке; см. docs/cdek-api-v2.md) ---
# CDEK_TEST_MODE=true  # не используется напрямую — переключатель в админке «СДЭК: тестовый контур»
# CDEK_ACCOUNT=
# CDEK_SECURE=
# CDEK_API_BASE_URL=https://api.edu.cdek.ru
# CDEK_WIDGET_DEFAULT_WEIGHT_G=3000  # граммы для виджета ПВЗ v3 (публичный checkout.cdek.widgetGoods)

# --- Ozon Acquiring / Ozon Pay Checkout (см. docs/ozon-pay-env.md) ---
# Базовый URL API без слэша; к нему добавляется /v1/createOrder
# OZON_PAY_API_BASE_URL=https://…
# OZON_PAY_ACCESS_KEY=
# OZON_PAY_SECRET_KEY=
# или: OZON_PAY_CLIENT_SECRET=  (секрет токена)
# OZON_PAY_WEBHOOK_SECRET=   (notificationSecretKey для POST /api/webhooks/ozon-pay/)
