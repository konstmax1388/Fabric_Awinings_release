# Скопируйте на сервер как .env рядом с backend/ (или экспортируйте в systemd).
# Секреты не коммитить. Пароли из чатов и мессенджеров — сменить после первого входа.

# Минимум ~50 символов; openssl rand -hex 32
DJANGO_SECRET_KEY=сгенерируйте-длинную-случайную-строку_минимум_50_символов_обязательно
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=fabrika-tentov.ru,www.fabrika-tentov.ru,127.0.0.1,localhost

# HTTPS за Nginx: редирект HTTP→HTTPS в Django (при необходимости выкл.: false, если только nginx редиректит)
DJANGO_SECURE_SSL_REDIRECT=true
# HSTS (секунды); 0 — отключить заголовок
DJANGO_SECURE_HSTS_SECONDS=31536000
# Опционально: логи в файл с ротацией (каталог создаётся автоматически)
# DJANGO_LOG_FILE=/var/www/kasatkin_da/data/www/fabrika-tentov.ru/backend/logs/django.log
# DJANGO_LOG_LEVEL=INFO

# Канонический URL витрины (HTTPS)
DJANGO_PUBLIC_SITE_URL=https://fabrika-tentov.ru
DJANGO_CSRF_TRUSTED_ORIGINS=https://fabrika-tentov.ru,https://www.fabrika-tentov.ru
DJANGO_CORS_ALLOWED_ORIGINS=https://fabrika-tentov.ru,https://www.fabrika-tentov.ru

# MySQL (имя БД и пользователя — из панели хостинга; пароль только на сервере)
DJANGO_MYSQL_HOST=127.0.0.1
DJANGO_MYSQL_PORT=3306
DJANGO_MYSQL_DATABASE=fabrica-tentov
DJANGO_MYSQL_USER=kasatkin_da
DJANGO_MYSQL_PASSWORD=
