FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

EXPOSE 5173

# Том `node_modules` перекрывает слой образа: при новых зависимостях без этого снова был бы старый набор пакетов.
CMD ["sh", "-c", "npm ci && exec npm run dev -- --host 0.0.0.0 --port 5173"]
