# Пример для Nginx: отредактируйте пути и upstream.
# upstream → Gunicorn из gunicorn.service.example (127.0.0.1:8001).

server {
    listen 80;
    server_name fabrika-tentov.ru www.fabrika-tentov.ru;
    client_max_body_size 32M;

    root /var/www/kasatkin_da/data/www/fabrika-tentov.ru/frontend/dist;

    location /api/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }

    location /admin/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /captcha/ {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /sitemap.xml {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /static/ {
        alias /var/www/kasatkin_da/data/www/fabrika-tentov.ru/backend/staticfiles/;
    }

    location /media/ {
        alias /var/www/kasatkin_da/data/www/fabrika-tentov.ru/backend/media/;
    }

    # Панель /staff/ (admin-ui → frontend/dist/staff): F5 на /staff/orders/1/show → staff/index.html, не витрина.
    location = /staff {
        return 302 /staff/;
    }

    location ^~ /staff/ {
        root /var/www/kasatkin_da/data/www/fabrika-tentov.ru/frontend/dist;
        index index.html;
        try_files $uri $uri/ /staff/index.html;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
