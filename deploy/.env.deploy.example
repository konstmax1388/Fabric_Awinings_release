# Скопируйте в deploy/.env.deploy (файл в .gitignore — не коммитить).
# Используется скриптом deploy/sync-to-production.sh

# SSH: пользователь и хост (как в ssh user@example.com)
# Пример: deploy@203.0.113.10 или deploy@server.example.com
DEPLOY_SSH_TARGET=user@ssh.example.com

# Абсолютный путь к корню репозитория на сервере (где лежат backend/, frontend/, .git)
DEPLOY_APP_PATH=/var/www/kasatkin_da/data/www/fabrika-tentov.ru

# Ветка для git pull
DEPLOY_GIT_BRANCH=main

# Имя systemd-сервиса Gunicorn (как в /etc/systemd/system/…). Пусто — без перезапуска.
DEPLOY_SYSTEMD_SERVICE=fabrika-gunicorn

# Чтобы деплой мог делать sudo systemctl restart без пароля, на сервере под root настройте sudoers:
#   см. deploy/sudoers/fabrica-gunicorn-restart.example
# Проверка от пользователя деплоя: sudo -n systemctl restart fabrika-gunicorn
#
# Если sudoers ещё не настроен — временно:
# DEPLOY_SKIP_SYSTEMD=1
